{
  "name": "navi",
  "version": "0.1.0",
  "description": "Navi cache warmer CLI",
  "main": "index.js",
  "scripts": {
    "test": "nyc npx jasmine spec/**/*.js",
    "lint": "eslint .",
    "lint_fix": "eslint . --fix",
    "lint_report": "eslint . --format html --output-file report/eslint-report.html",
    "coverage": "nyc jasmine",
    "report": "jscpd . --reporters console,html --output ./report/jscpd"
  },
  "author": "darthjee",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.0",
    "react": "^19.2.0",
    "react-bootstrap": "2.10.10",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-complexity": "^1.0.2",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jasmine": "2.10.1",
    "eslint-plugin-n": "16.6.2",
    "eslint-plugin-promise": "6.1.1",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-react-refresh": "0.4.1",
    "jasmine": "6.1.0",
    "jscpd": "4.0.4",
    "nyc": "15.1.0"
  },
  "jasmine": {
    "spec_dir": "spec",
    "spec_files": [
      "**/*[sS]pec.js"
    ]
  }
}
